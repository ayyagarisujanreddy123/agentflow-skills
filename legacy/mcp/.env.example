# =============================================================================
# AgentFlow MCP — Environment Variables
# =============================================================================
#
# Quick start:
#   1. Copy this file:        cp .env.example .env
#   2. Get an API key:        https://console.anthropic.com/settings/keys
#   3. Paste it below (replace the sk-ant-... placeholder).
#   4. Save. Done — `node test/integration.mjs` and `npx agentflow-mcp serve`
#      will pick it up automatically (loaded via `dotenv/config`).
#
# Where this key is used:
#   - All AgentFlow tool calls (read, search, gen, review, summarize,
#     transform, ask) bill to YOUR Anthropic account at Haiku/Sonnet rates.
#   - The integration test (~$0.005/run) and comparison benchmark
#     (~$0.10/run) both spend against this key.
#
# Resolution order (first non-empty wins):
#   1. `api_key:` field in ~/.agentflow/config.yaml
#   2. ANTHROPIC_API_KEY env var (this file, or your shell)
#
# Security:
#   - .env is gitignored — never commit a real key.
#   - For production / Claude Code use, prefer `npx agentflow-mcp init`
#     which writes the key to ~/.agentflow/config.yaml (chmod 600).
#   - Rotate keys at https://console.anthropic.com/settings/keys if leaked.
#
# =============================================================================

ANTHROPIC_API_KEY=sk-ant-...
