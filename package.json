    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "skills/",
    "agents/"
  ],
  "keywords": [
    "claude-code",
    "claude",
    "skills",
    "subagents",
    "anthropic",
    "ai-tools",
    "context-management"
  ],
